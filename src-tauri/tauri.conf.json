{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MotionAI",
  "version": "0.1.0",
  "identifier": "app.motionai.opennotion",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MotionAI",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' https://*; img-src 'self' data: https:; font-src 'self' data:"
    }
  },
  "plugins": {
    "deep-link": {
      "mobile": [
        {
          "scheme": ["opennotion"],
          "appLink": false
        }
      ],
      "desktop": {
        "schemes": ["opennotion"]
      }
    },
    "updater": {
      "pubkey": "",
      "endpoints": []
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  }
}
