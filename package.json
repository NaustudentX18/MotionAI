{
  "name": "motionai-workspace",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "signaling": "node signaling-server.js",
    "dev:all": "npm-run-all --parallel signaling dev",
    "verify:static": "node scripts/static-verify.mjs",
    "verify": "npm run verify:static && npm run lint && npm run test:ai && npm run test:spellcheck && npm run test:workspace && npm run test:schema && npm run test:import-export && npm run test:local-auth && npm run test:task-reminders && npm run test:smoke && npm run test:migration && npm run test:reliability && npm run test:torture && npm run test:importers && npm run test:webrtc-resilience",
    "test": "npm run verify:static && npm run test:ai && npm run test:spellcheck && npm run test:workspace && npm run test:schema && npm run test:import-export && npm run test:local-auth && npm run test:task-reminders && npm run test:migration && npm run test:reliability && npm run test:webrtc-resilience",
    "test:ai": "npx tsx scripts/ai-contract-tests.ts",
    "test:spellcheck": "npx tsx scripts/spellcheck-schema-tests.ts",
    "test:workspace": "npx tsx scripts/workspace-mock-tests.ts",
    "test:schema": "npx tsx scripts/workspace-schema-tests.ts",
    "test:import-export": "npx tsx scripts/import-export-tests.ts",
    "test:local-auth": "npx tsx scripts/local-auth-tests.ts",
    "test:task-reminders": "npx tsx scripts/task-reminder-tests.ts",
    "test:smoke": "node scripts/browser-smoke-test.mjs",
    "test:e2e": "playwright test",
    "test:migration": "npx tsx scripts/migration-tests.ts",
    "test:reliability": "npx tsx scripts/reliability-tests.ts",
    "test:torture": "npx tsx scripts/persistence-torture-tests.ts",
    "test:importers": "npx tsx scripts/importer-tests.ts",
    "test:webrtc-resilience": "npx tsx scripts/webrtc-resilience-tests.ts",
    "test:secret-redaction": "npm run build && npx tsx scripts/secret-redaction-tests.ts --start-server --port 3313 --secret motionai-secret-redaction-test"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@tauri-apps/api": "^2.11.0",
    "@tiptap/core": "^3.23.5",
    "@tiptap/extension-code-block-lowlight": "^3.23.5",
    "@tiptap/extension-collaboration-cursor": "^2.26.2",
    "@tiptap/extension-color": "^3.23.5",
    "@tiptap/extension-drag-handle": "^3.23.5",
    "@tiptap/extension-dropcursor": "^3.23.5",
    "@tiptap/extension-highlight": "^3.23.5",
    "@tiptap/extension-history": "^3.23.5",
    "@tiptap/extension-text-style": "^3.23.5",
    "@tiptap/extension-underline": "^3.23.5",
    "@tiptap/pm": "^3.23.5",
    "@tiptap/react": "^3.23.5",
    "@tiptap/starter-kit": "^3.23.5",
    "@tldraw/tldraw": "^5.0.1",
    "@vitejs/plugin-react": "^5.0.4",
    "@xenova/transformers": "^2.17.2",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "date-fns": "^4.2.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.13.0",
    "highlight.js": "^11.11.1",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "lowlight": "^3.3.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "tailwind-merge": "^3.6.0",
    "uuid": "^14.0.0",
    "vite": "^6.2.3",
    "voy-search": "^0.6.3",
    "ws": "^8.18.0",
    "y-indexeddb": "^9.0.12",
    "y-prosemirror": "^1.3.7",
    "y-webrtc": "^10.3.0",
    "yjs": "^13.6.30"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.14",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "npm-run-all": "^4.1.5",
    "playwright": "^1.60.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.6.0"
  },
  "description": "Self-hostable local-first intelligent workspace with block editing, BYO/local AI actions, Y.js persistence, and Tauri desktop.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/NaustudentX18/MotionAI.git"
  },
  "homepage": "https://github.com/NaustudentX18/MotionAI#readme",
  "bugs": {
    "url": "https://github.com/NaustudentX18/MotionAI/issues"
  }
}
