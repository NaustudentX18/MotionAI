# MotionAI environment variables
# Copy this file to .env and fill in your values.

# GitHub Personal Access Token (classic) with repo scope
# Stored securely at ~/.config/gh/hosts.yml for gh CLI
# To use with scripts: export GITHUB_TOKEN="MY_GITHUB_TOKEN"
GITHUB_TOKEN="MY_GITHUB_TOKEN"

# Server secret for webhook authentication
MOTIONAI_API_SECRET="MY_MOTIONAI_API_SECRET"

# AI Provider keys (keep local, never committed)
GEMINI_API_KEY="MY_GEMINI_API_KEY"
OPENAI_API_KEY="MY_OPENAI_API_KEY"
